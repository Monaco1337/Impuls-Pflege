generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────

enum RoleName {
  SUPER_ADMIN
  ADMIN
  RECRUITING
  OFFICE_STAFF
  CONTENT_MANAGER
  READ_ONLY
}

enum ApplicantStatus {
  NEU_EINGEGANGEN
  GESICHTET
  IN_PRUEFUNG
  INTERESSANT
  GESPRAECH_GEPLANT
  WARTELISTE
  ABGELEHNT
  EINGESTELLT
  ARCHIVIERT
}

enum InquiryStatus {
  NEU
  IN_BEARBEITUNG
  RUECKRUF_GEPLANT
  WARTET_AUF_RUECKMELDUNG
  ERLEDIGT
  ARCHIVIERT
}

enum InquiryPriority {
  NIEDRIG
  NORMAL
  HOCH
  DRINGEND
}

enum EmploymentType {
  VOLLZEIT
  TEILZEIT
  MINIJOB
  WERKSTUDENT
  PRAKTIKUM
  FREIBERUFLICH
}

// ─── User & Roles ─────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  avatar       String?
  active       Boolean  @default(true)
  role         RoleName @default(READ_ONLY)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedInquiries  Inquiry[]        @relation("InquiryAssignee")
  inquiryNotes       InquiryNote[]
  assignedApplicants Applicant[]      @relation("ApplicantAssignee")
  applicantNotes     ApplicantNote[]
  statusChanges      ApplicantStatusHistory[]
  contactJobs        JobPosting[]     @relation("JobContactPerson")
  contentUpdates     ContentBlock[]
  auditLogs          AuditLog[]

  @@map("users")
}

// ─── Inquiry Management ───────────────────────────────

model Inquiry {
  id                String          @id @default(cuid())
  fullName          String
  phone             String?
  email             String
  inquiryType       String
  message           String
  preferredCallback String?
  status            InquiryStatus   @default(NEU)
  priority          InquiryPriority @default(NORMAL)
  assignedToId      String?
  assignedTo        User?           @relation("InquiryAssignee", fields: [assignedToId], references: [id])
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  notes InquiryNote[]

  @@map("inquiries")
}

model InquiryNote {
  id        String   @id @default(cuid())
  inquiryId String
  inquiry   Inquiry  @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  content   String
  createdAt DateTime @default(now())

  @@map("inquiry_notes")
}

// ─── Applicant Management ─────────────────────────────

model Applicant {
  id              String          @id @default(cuid())
  firstName       String
  lastName        String
  email           String
  phone           String?
  address         String?
  positionApplied String
  availability    String?
  qualification   String?
  experience      String?
  motivation      String?
  source          String          @default("website")
  status          ApplicantStatus @default(NEU_EINGEGANGEN)
  assignedToId    String?
  assignedTo      User?           @relation("ApplicantAssignee", fields: [assignedToId], references: [id])
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  documents     ApplicantDocument[]
  notes         ApplicantNote[]
  statusHistory ApplicantStatusHistory[]
  tags          ApplicantTag[]
  jobPosting    JobPosting?     @relation(fields: [jobPostingId], references: [id])
  jobPostingId  String?

  @@map("applicants")
}

model ApplicantDocument {
  id          String   @id @default(cuid())
  applicantId String
  applicant   Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  fileName    String
  fileType    String
  filePath    String
  fileSize    Int
  uploadedAt  DateTime @default(now())

  @@map("applicant_documents")
}

model ApplicantNote {
  id          String   @id @default(cuid())
  applicantId String
  applicant   Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  content     String
  createdAt   DateTime @default(now())

  @@map("applicant_notes")
}

model ApplicantStatusHistory {
  id          String          @id @default(cuid())
  applicantId String
  applicant   Applicant       @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  fromStatus  ApplicantStatus
  toStatus    ApplicantStatus
  changedById String
  changedBy   User            @relation(fields: [changedById], references: [id])
  note        String?
  changedAt   DateTime        @default(now())

  @@map("applicant_status_history")
}

model Tag {
  id         String         @id @default(cuid())
  name       String         @unique
  color      String?
  createdAt  DateTime       @default(now())
  applicants ApplicantTag[]

  @@map("tags")
}

model ApplicantTag {
  applicantId String
  applicant   Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  tagId       String
  tag         Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([applicantId, tagId])
  @@map("applicant_tags")
}

// ─── Job Postings ─────────────────────────────────────

model JobPosting {
  id              String         @id @default(cuid())
  title           String
  slug            String         @unique
  department      String?
  location        String         @default("Unna")
  employmentType  EmploymentType @default(VOLLZEIT)
  workload        String?
  shortIntro      String
  description     String
  requirements    String?
  benefits        String?
  contactPersonId String?
  contactPerson   User?          @relation("JobContactPerson", fields: [contactPersonId], references: [id])
  active          Boolean        @default(true)
  publishDate     DateTime       @default(now())
  sortOrder       Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  applicants Applicant[]

  @@map("job_postings")
}

// ─── Content Management ───────────────────────────────

model ContentBlock {
  id          String   @id @default(cuid())
  key         String   @unique
  title       String?
  content     Json
  imageUrl    String?
  sortOrder   Int      @default(0)
  updatedAt   DateTime @updatedAt
  updatedById String?
  updatedBy   User?    @relation(fields: [updatedById], references: [id])

  @@map("content_blocks")
}

// ─── Audit Log ────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Settings ─────────────────────────────────────────

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value Json

  @@map("settings")
}
