# PostgreSQL — optional lokal: ohne Eintrag nutzt die App lib/database-url.ts (Dev).
# In Produktion / CI immer setzen.
# DATABASE_URL="postgresql://user:password@127.0.0.1:5432/impuls?schema=public"

# NextAuth
AUTH_SECRET="generate-a-secure-random-string-here"
# Lokal AUTH_URL weglassen, sonst rewrites NextAuth die Request-URL auf diesen Host/Port
# und Login/Cookies brechen auf einem anderen Dev-Port (z. B. 3010).
# In Produktion: exakte Site-URL, z. B. AUTH_URL="https://impuls-pflege.de"

# File Storage
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB="10"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="IMPULS Ambulanter Pflegedienst"
