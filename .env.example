# GitHub Contents API (Vercel: GIT_TOKEN + Repo; lokal: nur Dateien unter data/)
GIT_TOKEN=""
GITHUB_REPO_OWNER=""
GITHUB_REPO_NAME=""

# NextAuth
AUTH_SECRET="generate-a-secure-random-string-here"
# Lokal AUTH_URL weglassen, sonst rewrites NextAuth die Request-URL auf diesen Host/Port
# und Login/Cookies brechen auf einem anderen Dev-Port (z. B. 3010).
# In Produktion: exakte Site-URL, z. B. AUTH_URL="https://impuls-pflege.vercel.app"

# Optional: Upload-Größe (Admin-Bewerberdateien; hart begrenzt durch JSON-Speicher)
MAX_FILE_SIZE_MB="10"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="IMPULS Ambulanter Pflegedienst"

# Initiale JSON-Daten (ohne Git): npm run data:init
#
# ─── Admin-Login (Benutzername + Passwort) / Übergabe Live ─────────────────────
# Anmeldung erfolgt nur mit Benutzername (Feld "username" in users.json), nicht mit E-Mail.
# Passwort-Hashes liegen ausschließlich in users.json (lokal: data/, online: GitHub-Repo mit GIT_TOKEN).
# Neuen Hash erzeugen: npx tsx scripts/hash-password.ts "NeuesSicheresPasswort"
# Dann in users.json beim jeweiligen Benutzer "passwordHash" ersetzen und deployen / committen.
# Demo nach data:init (VOR Livegang ändern!): Benutzer admin, elena, daniel, recruiting, buero
#   — Passwort jeweils: Admin123!
