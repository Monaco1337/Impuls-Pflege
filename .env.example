# PostgreSQL
# Lokal optional (Default in lib/database-url.ts). Auf Vercel: Dashboard → Storage → Postgres
# installieren und Projekt verbinden — dann setzt Vercel DATABASE_URL automatisch.
# Alternative Variablen (POSTGRES_PRISMA_URL etc.) werden in lib/database-url.ts nach DATABASE_URL gespiegelt.
# DATABASE_URL="postgresql://user:password@127.0.0.1:5432/impuls?schema=public"

# Vercel Blob (Bewerber-Dateien auf Vercel; sonst lokales UPLOAD_DIR)
# In Vercel: Storage → Blob → Create Store → BLOB_READ_WRITE_TOKEN wird gesetzt.
# BLOB_READ_WRITE_TOKEN=""

# NextAuth
AUTH_SECRET="generate-a-secure-random-string-here"
# Lokal AUTH_URL weglassen, sonst rewrites NextAuth die Request-URL auf diesen Host/Port
# und Login/Cookies brechen auf einem anderen Dev-Port (z. B. 3010).
# In Produktion: exakte Site-URL, z. B. AUTH_URL="https://impuls-pflege.de"

# File Storage
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB="10"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="IMPULS Ambulanter Pflegedienst"
